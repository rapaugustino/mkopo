# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# --- Database (local PostgreSQL with the pgvector extension installed) ---
DATABASE_URL=postgresql+asyncpg://mkopo:mkopo@localhost:5432/mkopo
DATABASE_URL_SYNC=postgresql+psycopg://mkopo:mkopo@localhost:5432/mkopo

# --- Redis (for Arq queue) ---
REDIS_URL=redis://localhost:6379/0

# --- LLM ---
# Use the dated form of model IDs in production so a model alias rotating
# under you doesn't silently shift behaviour or invalidate eval trends.
# Override these when newer models land.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
LLM_DEFAULT_MODEL=claude-sonnet-4-5-20250929
LLM_HEAVY_MODEL=claude-opus-4-5-20251115
LLM_FAST_MODEL=claude-haiku-4-5-20251001
LLM_JUDGE_MODEL=claude-opus-4-5-20251115

# --- Embeddings (OpenAI) ---
# Used for comparable-loans search and "Ask the file" RAG.
# `-small` is ~5× cheaper than `-large`; at 1024 dimensions (Matryoshka-
# truncated from the native 1536), it's plenty for portfolio scope.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_DIMENSIONS=1024

# --- Email (Resend, outbound only) ---
# The from-address MUST be on a domain you've verified in Resend
# (https://resend.com/domains — DNS records published, status: verified).
# `ubunifutech.com` is the canonical Mkopo sending domain; replace the
# whole address with one on your own verified domain for your deployment.
#
# Outbound only. Mkopo does NOT process inbound email — borrowers
# reply in-app via the chat surface, not by email. See
# mkopo.tools.comms for the rationale.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_ADDRESS=mkopo@ubunifutech.com
RESEND_FROM_NAME=Mkopo

# --- Document storage ---
# STORAGE_BACKEND=local writes under STORAGE_ROOT on disk.
# STORAGE_BACKEND=s3 writes to S3_BUCKET. Point S3_ENDPOINT_URL at MinIO or
# LocalStack to exercise the S3 codepath without an AWS account.
STORAGE_BACKEND=local
STORAGE_ROOT=./var/storage
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=mkopo-documents-dev
S3_ENDPOINT_URL=

# --- Eval harness ---
EVAL_GOLDEN_SET_DIR=./evals/golden_sets
EVAL_RESULTS_DIR=./evals/results

# --- Auth (JWT signing) ---
# JWT_SECRET signs BOTH the staff session cookie (mkopo_staff_session,
# audience mkopo-staff) and the borrower session cookie (mkopo_session,
# audience mkopo-borrower). Different audience prevents cross-surface
# token reuse; same secret keeps key-management simple.
#
# MUST be overridden — the in-process placeholder default
# (config.py:jwt_secret) makes every install share signing keys, so
# any session can be forged. The startup banner emits ``degraded``
# until you override it.
#
# Generate a strong value:
#     python -c 'import secrets; print(secrets.token_urlsafe(48))'
#
# 32+ chars (256 bits) is the floor; 48-byte URL-safe (64 chars
# rendered) is the recommended default. Rotate by overwriting this
# value — all active sessions invalidate immediately, which is the
# only way rotation can work for a stateless JWT.
JWT_SECRET=

# --- Frontend URL (for CORS and email links) ---
FRONTEND_URL=http://localhost:3000
